                "  console.log(`Verdict: ${body.verdict}`);",
                "  console.log(`Sources: ${body.sources.map(s => s.source).join(', ')}`);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "6.3 Academic Query → Paper Sources",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/chat" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Should route to academic_paper and cite [Source: 2310.12815v5.pdf]",
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"What attack success values were reported in the research paper?\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Routed to paper', () => {",
