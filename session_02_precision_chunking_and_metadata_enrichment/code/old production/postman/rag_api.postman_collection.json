                "  pm.expect(body.routed_audience).to.eql('academic');",
                "  console.log(`Verdict: ${body.verdict}`);",
                "  console.log(`Sources: ${body.sources.map(s => s.source).join(', ')}`);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "6.4 Filtered Query (methodology only)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/chat" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Explicit content_type_filter bypasses audience routing.\nOnly retrieves chunks tagged as 'methodology'.",
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"What methodology is used?\",\n  \"content_type_filter\": \"methodology\"\n}" }
          }
        },
        {
          "name": "6.5 Cross-Document Query (no routing)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/chat" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "No clear audience → searches ALL documents.\nMay pull sources from multiple doc types.",
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"Compare the sandwich defense pattern across different document types\"\n}" }
          }
        },
        {
          "name": "6.6 Unrelated Query → CRAG INCORRECT",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/chat" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "This query has nothing to do with the corpus.\nCRAG should detect this and return verdict=INCORRECT.",
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"What is the stock price of Apple in 2025?\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('CRAG detected irrelevant query', () => {",
                "  const body = pm.response.json();",
                "  console.log(`Verdict: ${body.verdict}`);",
                "  console.log(`Answer: ${body.answer}`);",
                "  // CRAG should catch this as INCORRECT or AMBIGUOUS",
                "});"
              ]
            }
          }]
        },
        {
          "name": "6.7 Validation Error (too short)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/chat" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Query must be >= 3 chars. Should return 422.",
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"ab\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Validation error', () => pm.response.to.have.status(422));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "7️⃣ Final — Metrics & Grafana",
      "description": "After running all tests, check metrics and open Grafana.\n\nGrafana: http://localhost:3000 (admin/admin)",
      "item": [
        {
          "name": "7.1 Prometheus Metrics (after tests)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/metrics" },
            "description": "Check accumulated metrics:\n• rag_crag_verdicts_total — CORRECT vs INCORRECT counts\n• rag_query_routing_total — technical, academic, general, null counts\n• rag_enrichment_duration_seconds — regex vs LLM latency"
          }
        },
        {
          "name": "7.2 Health (final check)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health" },
            "description": "Final health check — confirm everything still healthy after load."
          }
        }
      ]
    }
  ]
}
