            "body": { "mode": "raw", "raw": "{\n  \"query\": \"How do I stop hackers from messing with my chatbot?\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Routed to FAQ', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.routed_audience).to.eql('general');",
                "  console.log(`Verdict: ${body.verdict}`);",
                "  console.log(`Sources: ${body.sources.map(s => s.source).join(', ')}`);",
                "  console.log(`Answer: ${body.answer.substring(0, 200)}...`);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "6.2 Technical Query → Wiki Sources",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/api/v1/chat" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Should route to internal_wiki and cite [Source: internal_wiki.md]",
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"What is the P50 latency budget for Tier 0 deployments?\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Routed to wiki', () => {",
                "  const body = pm.response.json();",
