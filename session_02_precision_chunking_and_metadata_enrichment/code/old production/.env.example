# LLM (Gemini)
GEMINI_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.0
GEMINI_MAX_TOKENS=2048

# Embeddings (Voyage AI)
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-3

# Vector Store (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=s2_enriched_rag

# Chunking
CHUNKING_STRATEGY=recursive           # fixed | recursive | semantic
CHUNKING_CHUNK_SIZE=500
CHUNKING_CHUNK_OVERLAP=50
CHUNKING_SEMANTIC_THRESHOLD=0.72      # cosine similarity for semantic chunking

# Retrieval + CRAG
RETRIEVER_INITIAL_K=10
RETRIEVER_RERANK_TOP_K=3
RETRIEVER_ENABLE_CRAG=true            # Enable Corrective RAG

# App
DEBUG=true
LOG_LEVEL=INFO
